// Zellij configuration
// Equivalent to the tmux config with vim-style navigation and session switcher

keybinds {
    // Session switcher (equivalent to tmux prefix + f)
    shared_except "locked" {
        bind "Ctrl f" {
            Run "zsh" "-c" "~/scripts/zellij-se" {
                close_on_exit true
            }
        }
    }

    // vim-like pane navigation in normal mode
    normal {
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt l" { MoveFocus "Right"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
    }
}

// General options
mouse_mode true
default_shell "zsh"
pane_frames false
